{
  "name": "@mnemo/github-sync",
  "version": "0.1.0",
  "description": "Mnemo GitHub connector — backfill + webhook sync of issues, PRs, and discussions.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "github-sync": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "backfill": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@mnemo/memory": "^0.1.0",
    "@octokit/rest": "^21.0.2",
    "@octokit/webhooks": "^13.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "license": "MIT"
}
